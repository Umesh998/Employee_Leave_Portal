@* ── AccessDenied.cshtml ── place at Views/Account/AccessDenied.cshtml ── *@
@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height:60vh">
    <i class="bi bi-shield-lock text-danger" style="font-size:4rem"></i>
    <h2 class="mt-3 fw-bold">Access Denied</h2>
    <p class="text-muted">You do not have permission to view this page.</p>
    <a asp-controller="Leave" asp-action="Dashboard" class="btn btn-primary mt-2">
        <i class="bi bi-house me-1"></i> Go to Dashboard
    </a>
</div>
