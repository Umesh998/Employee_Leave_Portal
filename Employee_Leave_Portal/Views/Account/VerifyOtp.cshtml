@model Employee_Leave_Portal.ViewModels.VerifyOtpVm
@{
    ViewData["Title"] = "Verify OTP";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify OTP — Employee Leave Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
            body {
                background: linear-gradient(135deg, #1E40AF 0%, #2563EB 60%, #3B82F6 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .otp-card {
                width: 100%;
                max-width: 420px;
                border-radius: 16px;
                border: none;
                box-shadow: 0 20px 60px rgba(0,0,0,.25);
            }

            .brand-header {
                background: #1E40AF;
                border-radius: 16px 16px 0 0;
                padding: 2rem;
                text-align: center;
                color: #fff;
            }

                .brand-header h1 {
                    font-size: 1.4rem;
                    font-weight: 700;
                    margin: .5rem 0 .25rem;
                }

                .brand-header p {
                    font-size: .85rem;
                    color: #BFDBFE;
                    margin: 0;
                }

            .otp-input {
                font-size: 1.8rem;
                font-weight: 700;
                letter-spacing: .5rem;
                text-align: center;
            }

            .masked-email {
                background: #EFF6FF;
                color: #1E40AF;
                padding: .4rem 1rem;
                border-radius: 8px;
                font-size: .88rem;
                font-weight: 600;
                display: inline-block;
                margin: .5rem 0 1.5rem;
            }
    </style>
</head>
<body>

    <div class="otp-card card">

        <div class="brand-header">
            <div style="font-size:2rem"><i class="bi bi-shield-lock"></i></div>
            <h1>Two-Factor Verification</h1>
            <p>Enter the OTP sent to your email</p>
        </div>

        <div class="card-body p-4">

            @if (TempData["AlertMessage"] is string msg)
            {
                <div class="alert alert-@(TempData["AlertSeverity"] ?? "info") alert-dismissible">
                    @msg
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="text-center">
                <p class="text-muted mb-1" style="font-size:.85rem">OTP sent to</p>
                <div class="masked-email">@Model.Email</div>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <form asp-action="VerifyOtp" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Email" type="hidden" />

                <div class="mb-4">
                    <label asp-for="Otp" class="form-label fw-semibold text-center w-100">
                        Enter 6-digit OTP
                    </label>
                    <input asp-for="Otp"
                           class="form-control otp-input"
                           maxlength="6"
                           placeholder="······"
                           autocomplete="one-time-code"
                           inputmode="numeric"
                           autofocus />
                    <span asp-validation-for="Otp" class="text-danger small d-block text-center mt-1"></span>
                    <div class="text-center text-muted mt-2" style="font-size:.8rem">
                        <i class="bi bi-clock me-1"></i> Expires in 5 minutes
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-check-circle me-1"></i> Verify & Login
                </button>
            </form>

            <!-- Resend OTP -->
            <form asp-action="ResendOtp" method="post" class="mt-3 text-center">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.Email" />
                <button type="submit" class="btn btn-link text-muted" style="font-size:.85rem">
                    <i class="bi bi-arrow-clockwise me-1"></i> Resend OTP
                </button>
            </form>

            <div class="text-center mt-2">
                <a asp-action="Login" class="text-muted" style="font-size:.82rem">
                    <i class="bi bi-arrow-left me-1"></i> Back to Login
                </a>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Auto-submit when 6 digits entered
        document.getElementById('Otp').addEventListener('input', function () {
        if (this.value.length === 6) {
        this.closest('form').submit();
        }
        });
    </script>

</body>
</html>
