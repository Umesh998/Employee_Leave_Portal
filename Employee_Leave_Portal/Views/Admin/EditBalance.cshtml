@model Employee_Leave_Portal.ViewModels.EditBalanceVm
@{
    ViewData["Title"] = "Edit Balance";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Edit Balance</h1>
        <p>@Model.EmployeeName — @Model.Year</p>
    </div>
    <a asp-action="Employees" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
        <div class="card">
            <div class="card-header">Adjust Leave Balance</div>
            <div class="card-body p-4">
                <form asp-action="EditBalance" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="EmployeeId" type="hidden" />
                    <input asp-for="EmployeeName" type="hidden" />
                    <input asp-for="Year" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="PaidLeaveBalance" class="form-label fw-semibold"></label>
                        <input asp-for="PaidLeaveBalance" class="form-control" step="0.5" type="number" />
                        <div class="form-text">Remaining paid leave days (max 18)</div>
                        <span asp-validation-for="PaidLeaveBalance" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ShortLeaveUsedThisMonth" class="form-label fw-semibold"></label>
                        <input asp-for="ShortLeaveUsedThisMonth" class="form-control" type="number" />
                        <div class="form-text">How many short leaves used this month (0–3 free tier)</div>
                        <span asp-validation-for="ShortLeaveUsedThisMonth" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-save me-1"></i> Save Balance
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}