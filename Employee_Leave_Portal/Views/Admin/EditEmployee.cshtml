@model Employee_Leave_Portal.ViewModels.EditEmployeeVm
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Edit Employee</h1>
    <a asp-action="Employees" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card">
            <div class="card-header">Edit Details</div>
            <div class="card-body p-4">
                <form asp-action="EditEmployee" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input value="@Model.Email" class="form-control bg-light" readonly />
                        <div class="form-text">Email cannot be changed.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EmployeeCode" class="form-label fw-semibold"></label>
                        <input asp-for="EmployeeCode" class="form-control" />
                        <span asp-validation-for="EmployeeCode" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-semibold"></label>
                        <select asp-for="Role" class="form-select"
                                asp-items="Html.GetEnumSelectList<Employee_Leave_Portal.Models.EmployeeRole>()"></select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DepartmentId" class="form-label fw-semibold"></label>
                        <select asp-for="DepartmentId" class="form-select"
                                asp-items="Model.Departments">
                            <option value="">— Select department —</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>

                  

                    <div class="mb-4 form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-save me-1"></i> Save Changes
                        </button>
                        <a asp-action="Employees" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
