@model Employee_Leave_Portal.ViewModels.EmployeeDetailVm
@{
    ViewData["Title"] = "Employee Detail";
    decimal totalDays = 18.0m;
    int paidPct       = (int)Math.Min(100, (Model.PaidLeaveBalance / totalDays) * 100);
    int usedPct       = (int)Math.Min(100, (Model.PaidLeaveUsed    / totalDays) * 100);
    string barColor   = Model.PaidLeaveBalance <= 3 ? "bg-danger"
                      : Model.PaidLeaveBalance <= 7 ? "bg-warning" : "bg-success";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>@Model.FullName</h1>
        <p>@Model.Email — @Model.DepartmentName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="EditBalance" asp-route-employeeId="@Model.Id"
           class="btn btn-outline-primary">
            <i class="bi bi-calendar-check me-1"></i> Edit Balance
        </a>
        <a asp-action="EditEmployee" asp-route-id="@Model.Id"
           class="btn btn-outline-secondary">
            <i class="bi bi-pencil me-1"></i> Edit Profile
        </a>
        <a asp-action="Employees" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<!-- ── Profile + Balance Row ──────────────────────────────────────────── -->
<div class="row g-3 mb-4">

    <!-- Profile card -->
    <div class="col-md-3">
        <div class="card h-100 p-3 text-center">
            <div style="width:64px;height:64px;border-radius:50%;background:#EFF6FF;
                        display:flex;align-items:center;justify-content:center;
                        margin:0 auto 12px;font-size:1.8rem;color:#2563EB">
                <i class="bi bi-person"></i>
            </div>
            <div class="fw-bold">@Model.FullName</div>
            <div class="text-muted" style="font-size:.82rem">@Model.Email</div>
            <div class="mt-2">
                <span class="badge @(Model.Role == "Admin" ? "bg-dark" :
                                     Model.Role == "HR"    ? "bg-info text-dark" :
                                     Model.Role == "HOD"   ? "bg-primary" : "bg-secondary")">
                    @Model.Role
                </span>
                @if (Model.IsActive)
                {
                    <span class="badge bg-success ms-1">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary ms-1">Inactive</span>
                }
            </div>
        </div>
    </div>

    <!-- Paid leave balance card -->
    <div class="col-md-5">
        <div class="card h-100 p-3">
            <div class="text-muted mb-1" style="font-size:.78rem;text-transform:uppercase;
                        font-weight:600;letter-spacing:.05em">
                Paid Leave — @Model.Year
            </div>
            <div class="d-flex justify-content-between mb-1">
                <span style="font-size:.85rem">Remaining</span>
                <span class="fw-bold @(Model.PaidLeaveBalance <= 3 ? "text-danger" :
                                       Model.PaidLeaveBalance <= 7 ? "text-warning" : "text-success")">
                    @Model.PaidLeaveBalance.ToString("F1") days
                </span>
            </div>
            <div class="progress mb-3" style="height:10px">
                <div class="progress-bar @barColor" style="width:@paidPct%"></div>
            </div>
            <div class="row g-2 text-center">
                <div class="col-4">
                    <div style="font-size:1.4rem;font-weight:700;color:#2563EB">
                        @totalDays.ToString("F0")
                    </div>
                    <div class="text-muted" style="font-size:.75rem">Total</div>
                </div>
                <div class="col-4">
                    <div style="font-size:1.4rem;font-weight:700;color:#10B981">
                        @Model.PaidLeaveBalance.ToString("F1")
                    </div>
                    <div class="text-muted" style="font-size:.75rem">Remaining</div>
                </div>
                <div class="col-4">
                    <div style="font-size:1.4rem;font-weight:700;color:#EF4444">
                        @Model.PaidLeaveUsed.ToString("F1")
                    </div>
                    <div class="text-muted" style="font-size:.75rem">Used</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Short leave + summary card -->
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="text-muted mb-2" style="font-size:.78rem;text-transform:uppercase;
                        font-weight:600;letter-spacing:.05em">
                Short Leave — This Month
            </div>
            <div class="d-flex justify-content-between mb-3">
                <div class="text-center">
                    <div style="font-size:1.6rem;font-weight:700;
                                color:@(Model.ShortLeaveUsedThisMonth >= 3 ? "#EF4444" : "#2563EB")">
                        @Model.ShortLeaveUsedThisMonth
                    </div>
                    <div class="text-muted" style="font-size:.75rem">Used</div>
                </div>
                <div class="text-center">
                    <div style="font-size:1.6rem;font-weight:700;color:#10B981">
                        @Model.ShortLeaveFreeRemaining
                    </div>
                    <div class="text-muted" style="font-size:.75rem">Free Left</div>
                </div>
                <div class="text-center">
                    <div style="font-size:1.6rem;font-weight:700;color:#64748B">3</div>
                    <div class="text-muted" style="font-size:.75rem">Monthly Limit</div>
                </div>
            </div>

            <hr class="my-2" />

            <!-- Request summary -->
            <div class="row g-1 text-center">
                <div class="col-3">
                    <div class="fw-bold text-success">@Model.ApprovedCount</div>
                    <div style="font-size:.7rem;color:#64748B">Approved</div>
                </div>
                <div class="col-3">
                    <div class="fw-bold text-warning">@Model.PendingCount</div>
                    <div style="font-size:.7rem;color:#64748B">Pending</div>
                </div>
                <div class="col-3">
                    <div class="fw-bold text-danger">@Model.RejectedCount</div>
                    <div style="font-size:.7rem;color:#64748B">Rejected</div>
                </div>
                <div class="col-3">
                    <div class="fw-bold" style="color:#991B1B">@Model.LossOfPayCount</div>
                    <div style="font-size:.7rem;color:#64748B">LOP</div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ── Leave History Table ─────────────────────────────────────────────── -->
<div class="card">
    <div class="card-header">
        Full Leave History
        <span class="badge bg-secondary ms-2">@Model.TotalRequests</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Requests.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-calendar-x fs-1"></i>
                <p class="mt-2">No leave requests found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Leave Date</th>
                            <th>Type</th>
                            <th>Hours</th>
                            <th>Applied On</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>LOP</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Requests)
                        {
                            var badgeClass = r.Status switch
                            {
                                "Pending_HOD" => "badge-pending-hod",
                                "Pending_HR" => "badge-pending-hr",
                                "Approved" => "badge-approved",
                                "Rejected" => "badge-rejected",
                                _ => "bg-secondary text-white"
                            };
                            <tr>
                                <td>@r.LeaveDate.ToString("dd MMM yyyy")</td>
                                <td>@r.LeaveType.Replace("Leave", " Leave")</td>
                                <td>@r.Hours hrs</td>
                                <td>@r.DateApplied.ToString("dd MMM yyyy")</td>
                                <td style="font-size:.83rem;max-width:180px">
                                    @(string.IsNullOrWhiteSpace(r.Reason) ? "—" : r.Reason)
                                </td>
                                <td>
                                    <span class="status-badge @badgeClass">
                                        @r.Status.Replace("_", " ")
                                    </span>
                                </td>
                                <td>
                                    @if (r.IsLossOfPay)
                                    {
                                        <span class="lop-pill">LOP</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
