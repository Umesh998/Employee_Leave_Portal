@model Employee_Leave_Portal.ViewModels.BulkUploadResultVm
@{
    ViewData["Title"] = "Upload Result";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Upload Result</h1>
    <a asp-action="BulkUpload" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Upload Another
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">

        <!-- Summary cards -->
        <div class="row g-3 mb-4">
            <div class="col-4">
                <div class="card text-center p-3">
                    <div style="font-size:2rem;font-weight:700;color:#2563EB">@Model.TotalRows</div>
                    <div class="text-muted" style="font-size:.8rem">Rows Processed</div>
                </div>
            </div>
            <div class="col-4">
                <div class="card text-center p-3">
                    <div style="font-size:2rem;font-weight:700;color:#10B981">@Model.Inserted</div>
                    <div class="text-muted" style="font-size:.8rem">Inserted</div>
                </div>
            </div>
            <div class="col-4">
                <div class="card text-center p-3">
                    <div style="font-size:2rem;font-weight:700;color:#F59E0B">@Model.Updated</div>
                    <div class="text-muted" style="font-size:.8rem">Updated</div>
                </div>
            </div>
        </div>

        <!-- Errors -->
        @if (Model.Errors.Any())
        {
            <div class="card border-danger">
                <div class="card-header text-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @Model.Errors.Count Error(s)
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var err in Model.Errors)
                        {
                            <li class="list-group-item text-danger" style="font-size:.85rem">
                                <i class="bi bi-x-circle me-2"></i>@err
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill me-2"></i>
                All rows processed successfully with no errors.
            </div>
        }

        <div class="mt-3">
            <a asp-action="Employees" class="btn btn-primary">
                <i class="bi bi-people me-1"></i> View Employees
            </a>
        </div>

    </div>
</div>
