@model Employee_Leave_Portal.ViewModels.HrQueueVm
@{
    ViewData["Title"] = "HR Approvals";
}

<div class="page-header">
    <h1>HR Approvals</h1>
    <p>All requests forwarded by HODs awaiting final approval.</p>
</div>

<div class="card">
    <div class="card-header">
        Pending HR Review
        <span class="badge bg-primary ms-2">@Model.Requests.Count</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Requests.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-2">No requests pending HR review.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Department</th>
                            <th>Leave Type</th>
                            <th>Leave Date</th>
                            <th>Hours</th>
                            <th>Applied On</th>
                            <th>LOP</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Requests)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@r.EmployeeName</div>
                                    <div class="text-muted" style="font-size:.78rem">@r.EmployeeEmail</div>
                                </td>
                                <td>@r.DepartmentName</td>
                                <td>@r.LeaveType.Replace("Leave", " Leave")</td>
                                <td>@r.LeaveDate.ToString("dd MMM yyyy")</td>
                                <td>@r.Hours hrs</td>
                                <td>@r.DateApplied.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (r.IsLossOfPay)
                                    {
                                        <span class="lop-pill">LOP</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Review" asp-route-id="@r.Id"
                                       class="btn btn-sm btn-primary">
                                        Review
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
