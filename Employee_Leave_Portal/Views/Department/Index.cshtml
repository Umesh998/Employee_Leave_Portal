@* ── Index.cshtml ── place at Views/Department/Index.cshtml ── *@
@model List<Employee_Leave_Portal.ViewModels.DepartmentRowVm>
@{
    ViewData["Title"] = "Departments";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Departments</h1>
        <p>@Model.Count department(s) in the system</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Department
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Department</th>
                        <th>Head of Department</th>
                        <th>Employees</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@d.DepartmentName</td>
                            <td>@d.HODName</td>
                            <td>
                                <span class="badge bg-secondary">@d.EmployeeCount</span>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@d.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@d.Id"
                                          method="post"
                                          onsubmit="return confirm('Delete @d.DepartmentName?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
